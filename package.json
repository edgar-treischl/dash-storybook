{
  "name": "dash-storybook",
  "version": "1.0.0",
  "description": "Storybook documentation site for Dash UI components",
  "private": true,
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint . --ext .ts,.tsx",
    "update-components": "pnpm update @edgar-treischl/dash-ui && echo '✓ Components updated! Restart Storybook to see changes.'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.6.0",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-interactions": "^8.6.0",
    "@storybook/addon-links": "^8.6.0",
    "@storybook/blocks": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.6.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.0"
  },
  "type": "module",
  "dependencies": {
    "@edgar-treischl/dash-ui": "github:edgar-treischl/dash-ui"
  }
}
